{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CloudpilotEmu",
  "version": "0.1.0",
  "identifier": "io.github.cloudpilotemu",
  "build": {
    "frontendDist": "https://cloudpilot-emu.github.io/app",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "CloudpilotEmu",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
